# --- Database (Postgres + pgvector; Supabase in production) ---
DATABASE_URL=postgresql+psycopg://localhost:5432/refund_agent
# Supabase: postgresql+psycopg://postgres:<password>@db.<project>.supabase.co:5432/postgres

# --- LLM (any OpenAI-compatible server: Ollama locally, vLLM in production) ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:3b
# Production (vLLM): LLM_BASE_URL=http://<gpu-host>:8000/v1  LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_API_KEY=not-needed

# --- Embeddings (OpenAI-compatible /v1/embeddings) ---
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Voice (optional; leave empty to disable the mic) ---
OPENAI_API_KEY=

# --- LangFuse (optional; leave empty to disable tracing) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
